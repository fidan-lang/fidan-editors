{
    "name": "fidan",
    "displayName": "Fidan",
    "description": "Syntax highlighting, formatting and language server support for the Fidan programming language.",
    "version": "1.0.0",
    "publisher": "AppSolves",
    "license": "SEE LICENSE IN LICENSE",
    "icon": "./icons/icon_128x128.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/AppSolves/fidan"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Linters",
        "Debuggers",
        "Snippets"
    ],
    "keywords": [
        "fidan",
        "fdn"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "fidan",
                "aliases": [
                    "Fidan",
                    "fidan"
                ],
                "extensions": [
                    ".fdn"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/icon.png",
                    "dark": "./icons/icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "fidan",
                "scopeName": "source.fidan",
                "path": "./syntaxes/fidan.tmLanguage.json"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "fidan",
                "scopes": {
                    "function": [
                        "entity.name.function.fidan"
                    ],
                    "function.declaration": [
                        "entity.name.function.fidan"
                    ],
                    "method": [
                        "entity.name.function.member.fidan"
                    ],
                    "method.declaration": [
                        "entity.name.function.member.fidan"
                    ],
                    "class": [
                        "entity.name.class.fidan"
                    ],
                    "class.declaration": [
                        "entity.name.class.fidan"
                    ],
                    "variable": [
                        "variable.other.readwrite.fidan"
                    ],
                    "variable.declaration": [
                        "variable.other.readwrite.fidan"
                    ],
                    "variable.declaration.readonly": [
                        "variable.other.constant.fidan"
                    ],
                    "parameter": [
                        "variable.parameter.fidan"
                    ],
                    "parameter.declaration": [
                        "variable.parameter.fidan"
                    ],
                    "property": [
                        "variable.other.property.fidan"
                    ],
                    "type": [
                        "support.type.primitive.fidan"
                    ]
                }
            }
        ],
        "configuration": {
            "title": "Fidan",
            "properties": {
                "fidan.server.path": {
                    "type": "string",
                    "default": "fidan",
                    "description": "Path to the `fidan` binary used for the language server. Defaults to `fidan` on PATH."
                },
                "fidan.server.extraArgs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Extra arguments forwarded to `fidan lsp`."
                },
                "fidan.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace LSP communication in the Output channel."
                },
                "fidan.format.indentWidth": {
                    "type": "number",
                    "default": 4,
                    "description": "Number of spaces per indent level used by `fidan format`."
                },
                "fidan.format.maxLineLen": {
                    "type": "number",
                    "default": 100,
                    "description": "Target maximum line length used by `fidan format`."
                },
                "fidan.format.onSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Format Fidan files automatically on save."
                },
                "fidan.run.terminalName": {
                    "type": "string",
                    "default": "Fidan",
                    "description": "Name of the integrated terminal used by the 'Fidan: Run Current File' command."
                },
                "fidan.run.reload": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--reload` to `fidan run` (watch source files and re-run on change)."
                },
                "fidan.run.strict": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--strict` to `fidan run` (treat select warnings as errors)."
                },
                "fidan.run.trace": {
                    "type": "string",
                    "enum": [
                        "none",
                        "short",
                        "full",
                        "compact"
                    ],
                    "enumDescriptions": [
                        "No call-stack trace on panic",
                        "Short call-stack trace",
                        "Full call-stack trace",
                        "Compact call-stack trace"
                    ],
                    "default": "none",
                    "description": "Pass `--trace <mode>` to `fidan run` and `fidan repl`."
                },
                "fidan.run.sandbox": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--sandbox` to `fidan run` (deny all file/env/net access by default)."
                },
                "fidan.run.sandbox.allowRead": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Path prefixes passed via `--allow-read` when `fidan.run.sandbox` is enabled. Use `*` to allow all."
                },
                "fidan.run.sandbox.allowWrite": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Path prefixes passed via `--allow-write` when `fidan.run.sandbox` is enabled."
                },
                "fidan.run.sandbox.allowEnv": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--allow-env` when `fidan.run.sandbox` is enabled."
                },
                "fidan.run.sandbox.allowNet": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--allow-net` when `fidan.run.sandbox` is enabled."
                },
                "fidan.run.sandbox.allowSpawn": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--allow-spawn` when `fidan.run.sandbox` is enabled."
                },
                "fidan.run.sandbox.timeLimit": {
                    "type": "number",
                    "minimum": 0,
                    "default": 0,
                    "description": "Wall-time limit in seconds (`--time-limit`) when sandbox is active. 0 = no limit."
                },
                "fidan.run.sandbox.memLimit": {
                    "type": "number",
                    "minimum": 0,
                    "default": 0,
                    "description": "Memory limit in MB (`--mem-limit`) when sandbox is active. 0 = no limit."
                },
                "fidan.run.jitThreshold": {
                    "type": "number",
                    "default": 500,
                    "description": "JIT compilation threshold (`--jit-threshold`). 0 = disable JIT."
                },
                "fidan.run.suppress": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Diagnostic codes to suppress in `fidan run` (e.g. `[\"W5003\", \"W1004\"]`)."
                },
                "fidan.run.emit": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "tokens",
                            "ast",
                            "hir",
                            "mir"
                        ]
                    },
                    "default": [],
                    "description": "Emit intermediate representations during `fidan run`."
                },
                "fidan.run.maxErrors": {
                    "type": "number",
                    "default": 0,
                    "description": "Stop after this many errors in `fidan run`. 0 = no limit."
                },
                "fidan.check.strict": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--strict` to `fidan check`."
                },
                "fidan.check.maxErrors": {
                    "type": "number",
                    "default": 0,
                    "description": "Stop after this many errors in `fidan check`. 0 = no limit."
                },
                "fidan.check.suppress": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Diagnostic codes suppressed in `fidan check` and `fidan test`."
                },
                "fidan.build.release": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pass `--release` to `fidan build`."
                },
                "fidan.build.outputPath": {
                    "type": "string",
                    "default": "",
                    "description": "Output binary path for `fidan build` (empty = default `out`)."
                },
                "fidan.build.emit": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "tokens",
                            "ast",
                            "hir",
                            "mir"
                        ]
                    },
                    "default": [],
                    "description": "Emit intermediate representations during `fidan build`."
                },
                "fidan.profile.outputFile": {
                    "type": "string",
                    "default": "",
                    "description": "Write profiling data to this JSON file path (empty = print to terminal)."
                }
            }
        },
        "snippets": [
            {
                "language": "fidan",
                "path": "./syntaxes/fidan.code-snippets.json"
            }
        ],
        "commands": [
            {
                "command": "fidan.restartServer",
                "title": "Fidan: Restart Language Server"
            },
            {
                "command": "fidan.showOutput",
                "title": "Fidan: Show Language Server Output"
            },
            {
                "command": "fidan.runFile",
                "title": "Fidan: Run Current File",
                "icon": "$(play)"
            },
            {
                "command": "fidan.checkFile",
                "title": "Fidan: Check File"
            },
            {
                "command": "fidan.fixFile",
                "title": "Fidan: Fix File"
            },
            {
                "command": "fidan.formatFile",
                "title": "Fidan: Format Current File"
            },
            {
                "command": "fidan.buildFile",
                "title": "Fidan: Build File"
            },
            {
                "command": "fidan.testFile",
                "title": "Fidan: Run Tests in Current File",
                "icon": "$(beaker)"
            },
            {
                "command": "fidan.profileFile",
                "title": "Fidan: Profile Current File"
            },
            {
                "command": "fidan.explainCode",
                "title": "Fidan: Explain Diagnostic Code"
            },
            {
                "command": "fidan.explainLine",
                "title": "Fidan: Explain Current Line(s)"
            },
            {
                "command": "fidan.newProject",
                "title": "Fidan: New Project"
            },
            {
                "command": "fidan.openRepl",
                "title": "Fidan: Open REPL"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "fidan.runFile",
                    "when": "resourceLangId == fidan",
                    "group": "navigation"
                },
                {
                    "command": "fidan.testFile",
                    "when": "resourceLangId == fidan",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "fidan.runFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@1"
                },
                {
                    "command": "fidan.checkFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@3"
                },
                {
                    "command": "fidan.testFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@4"
                },
                {
                    "command": "fidan.fixFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@5"
                },
                {
                    "command": "fidan.explainLine",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@6"
                }
            ],
            "explorer/context": [
                {
                    "command": "fidan.runFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@1"
                },
                {
                    "command": "fidan.checkFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@2"
                },
                {
                    "command": "fidan.testFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@3"
                },
                {
                    "command": "fidan.fixFile",
                    "when": "resourceLangId == fidan",
                    "group": "fidan@4"
                }
            ]
        },
        "configurationDefaults": {
            "[fidan]": {
                "editor.semanticHighlighting.enabled": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "explicit"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run sync-license && npm run compile",
        "sync-license": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\"",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.3",
        "typescript": "^5.4.0"
    }
}