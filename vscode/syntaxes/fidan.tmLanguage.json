{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Fidan",
    "scopeName": "source.fidan",
    "fileTypes": ["fdn"],
    "patterns": [
        { "include": "#block-comment" },
        { "include": "#line-comment" },
        { "include": "#decorator" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#parallel-action-declaration" },
        { "include": "#action-declaration" },
        { "include": "#object-declaration" },
        { "include": "#task-declaration" },
        { "include": "#keyword-declaration" },
        { "include": "#keyword-control" },
        { "include": "#keyword-modifier" },
        { "include": "#keyword-operator" },
        { "include": "#type-builtin" },
        { "include": "#constant-language" },
        { "include": "#function-call" },
        { "include": "#type-user" },
        { "include": "#operator-symbolic" },
        { "include": "#identifier" }
    ],
    "repository": {

        "block-comment": {
            "name": "comment.block.fidan",
            "begin": "#/",
            "end": "/#",
            "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.fidan" } },
            "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.fidan" } },
            "patterns": [
                { "include": "#block-comment" }
            ]
        },

        "line-comment": {
            "match": "##.*$|#(?![/]).*$",
            "name": "comment.line.number-sign.fidan",
            "captures": {
                "0": { "name": "comment.line.number-sign.fidan" }
            }
        },

        "decorator": {
            "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.operator.decorator.fidan" },
                "2": { "name": "entity.name.function.decorator.fidan" }
            }
        },

        "string": {
            "name": "string.quoted.double.fidan",
            "begin": "\"",
            "end": "\"",
            "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.fidan" } },
            "endCaptures":   { "0": { "name": "punctuation.definition.string.end.fidan" } },
            "patterns": [
                { "include": "#string-escape" },
                { "include": "#string-interpolation" }
            ]
        },

        "string-escape": {
            "match": "\\\\[nrt\\\\\"{}]",
            "name": "constant.character.escape.fidan"
        },

        "string-interpolation": {
            "name": "meta.template.expression.fidan",
            "begin": "(?<!\\\\)\\{",
            "end": "\\}",
            "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.fidan" } },
            "endCaptures":   { "0": { "name": "punctuation.definition.template-expression.end.fidan" } },
            "patterns": [
                { "include": "#block-comment" },
                { "include": "#line-comment" },
                { "include": "#string" },
                { "include": "#number" },
                { "include": "#keyword-control" },
                { "include": "#keyword-operator" },
                { "include": "#type-builtin" },
                { "include": "#constant-language" },
                { "include": "#operator-symbolic" },
                { "include": "#identifier" }
            ]
        },

        "number": {
            "patterns": [
                {
                    "match": "0[xX][0-9A-Fa-f][0-9A-Fa-f_]*",
                    "name": "constant.numeric.hex.fidan"
                },
                {
                    "match": "0[bB][01][01_]*",
                    "name": "constant.numeric.binary.fidan"
                },
                {
                    "match": "0[oO][0-7][0-7_]*",
                    "name": "constant.numeric.octal.fidan"
                },
                {
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b",
                    "name": "constant.numeric.float.fidan"
                },
                {
                    "match": "\\b[0-9][0-9_]*\\b",
                    "name": "constant.numeric.integer.fidan"
                }
            ]
        },

        "keyword-declaration": {
            "match": "\\b(var|const|action|object|new|extends|export|use|as|test)\\b",
            "name": "keyword.declaration.fidan"
        },

        "keyword-control": {
            "match": "\\b(if|otherwise|else|when|for|in|while|break|stop|continue|return|attempt|try|catch|finally|spawn|await|concurrent|parallel|task|check|panic|throw|sep)\\b",
            "name": "keyword.control.fidan"
        },

        "keyword-modifier": {
            "match": "\\b(certain|optional|oftype|returns|with|this|parent)\\b",
            "name": "keyword.other.modifier.fidan"
        },

        "keyword-operator": {
            "match": "\\b(and|or|not|is|equals|notequals|lessthan|greaterthan|lessthanorequals|greaterthanorequals|mod|pow|also|set)\\b",
            "name": "keyword.operator.word.fidan"
        },

        "type-builtin": {
            "match": "\\b(integer|int|float|decimal|boolean|bool|string|text|flexible|dynamic|list|map|dict|tuple|Shared|Pending|WeakShared)\\b",
            "name": "support.type.primitive.fidan"
        },

        "constant-language": {
            "match": "\\b(true|false|True|False|nothing)\\b",
            "name": "constant.language.fidan"
        },

        "type-user": {
            "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
            "name": "entity.name.class.fidan"
        },

        "action-declaration": {
            "match": "\\b(action)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
            "captures": {
                "1": { "name": "keyword.declaration.fidan" },
                "2": { "name": "entity.name.function.fidan" },
                "4": { "name": "keyword.declaration.fidan" },
                "5": { "name": "entity.name.class.fidan" }
            }
        },

        "parallel-action-declaration": {
            "match": "\\b(parallel)\\s+(action)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.control.fidan" },
                "2": { "name": "keyword.declaration.fidan" },
                "3": { "name": "entity.name.function.fidan" }
            }
        },

        "object-declaration": {
            "match": "\\b(object)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*))?\\b",
            "captures": {
                "1": { "name": "keyword.declaration.fidan" },
                "2": { "name": "entity.name.class.fidan" },
                "4": { "name": "keyword.declaration.fidan" },
                "5": { "name": "entity.name.class.fidan" }
            }
        },

        "task-declaration": {
            "match": "\\b(task)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.control.fidan" },
                "2": { "name": "entity.name.function.fidan" }
            }
        },

        "function-call": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
            "captures": {
                "1": { "name": "entity.name.function.call.fidan" }
            }
        },

        "operator-symbolic": {
            "patterns": [
                {
                    "match": "\\.\\.\\.|\\.\\.",
                    "name": "keyword.operator.range.fidan"
                },
                {
                    "match": "\\?\\?",
                    "name": "keyword.operator.null-coalescing.fidan"
                },
                {
                    "match": "(\\+|-|\\*|/|%)=",
                    "name": "keyword.operator.assignment.compound.fidan"
                },
                {
                    "match": "=>",
                    "name": "keyword.operator.fat-arrow.fidan"
                },
                {
                    "match": "->",
                    "name": "keyword.operator.arrow.fidan"
                },
                {
                    "match": "::",
                    "name": "keyword.operator.path.fidan"
                },
                {
                    "match": "==|!=|<=|>=|<<|>>|<|>",
                    "name": "keyword.operator.comparison.fidan"
                },
                {
                    "match": "&&|\\|\\||!",
                    "name": "keyword.operator.logical.fidan"
                },
                {
                    "match": "&|\\||\\^",
                    "name": "keyword.operator.bitwise.fidan"
                },
                {
                    "match": "\\*\\*|\\+|-|\\*|/|%",
                    "name": "keyword.operator.arithmetic.fidan"
                },
                {
                    "match": "=(?![>=])",
                    "name": "keyword.operator.assignment.fidan"
                }
            ]
        },

        "identifier": {
            "match": "[A-Za-z_][A-Za-z0-9_]*",
            "name": "variable.other.fidan"
        }
    }
}
