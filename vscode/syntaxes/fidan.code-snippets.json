{
  "Action declaration": {
    "prefix": "action",
    "body": [
      "action ${1:name} with (",
      "\tcertain ${2:param} oftype ${3:string},",
      ") returns ${4:nothing} {",
      "\t$0",
      "}"
    ],
    "description": "Declare a new action"
  },
  "Action no params": {
    "prefix": "action0",
    "body": [
      "action ${1:name} {",
      "\t$0",
      "}"
    ],
    "description": "Declare an action with no parameters"
  },
  "Nested action declaration": {
    "prefix": "laction",
    "body": [
      "action ${1:name} with (",
      "\tcertain ${2:param} oftype ${3:integer},",
      ") returns ${4:nothing} {",
      "\t$0",
      "}"
    ],
    "description": "Declare a nested local action inside the current scope"
  },
  "Object declaration": {
    "prefix": "object",
    "body": [
      "object ${1:Name} {",
      "\tvar ${2:field} oftype ${3:string}",
      "",
      "\tnew with (",
      "\t\tcertain ${2:field} oftype ${3:string},",
      "\t) {",
      "\t\tthis.${2:field} = ${2:field}",
      "\t}",
      "",
      "\t$0",
      "}"
    ],
    "description": "Declare a new object type"
  },
  "Object with extends": {
    "prefix": "objectx",
    "body": [
      "object ${1:Name} extends ${2:Parent} {",
      "\t$0",
      "}"
    ],
    "description": "Declare an object that extends another"
  },
  "Enum declaration": {
    "prefix": "enum",
    "body": [
      "enum ${1:Result} {",
      "\t${2:Ok}(string)",
      "\t${3:Err}(dynamic)",
      "}"
    ],
    "description": "Declare an enum with payload variants"
  },
  "Extern action": {
    "prefix": "extern",
    "body": [
      "@extern(\"${1:self}\", symbol = \"${2:native_symbol}\")",
      "action ${3:name} with (",
      "\tcertain ${4:value} oftype integer,",
      ") returns ${5:integer}"
    ],
    "description": "Declare a native @extern action"
  },
  "Variable declaration": {
    "prefix": "var",
    "body": "var ${1:name} = ${0:value}",
    "description": "Declare a variable"
  },
  "Typed variable declaration": {
    "prefix": "vart",
    "body": "var ${1:name} oftype ${2:type} = ${0:value}",
    "description": "Declare a typed variable"
  },
  "Const variable declaration": {
    "prefix": "const",
    "body": "const var ${1:name} = ${0:value}",
    "description": "Declare a constant variable"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "If-otherwise statement": {
    "prefix": "ifo",
    "body": [
      "if ${1:condition} {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:collection} {",
      "\t$0",
      "}"
    ],
    "description": "For-in loop"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "Attempt-catch block": {
    "prefix": "attempt",
    "body": [
      "attempt {",
      "\t$1",
      "} catch ${2:err} {",
      "\t$0",
      "}"
    ],
    "description": "Attempt-catch error handling block"
  },
  "Attempt-catch-finally block": {
    "prefix": "attemptf",
    "body": [
      "attempt {",
      "\t$1",
      "} catch ${2:err} {",
      "\t$3",
      "} finally {",
      "\t$0",
      "}"
    ],
    "description": "Attempt-catch-finally error handling block"
  },
  "Use stdlib import": {
    "prefix": "use",
    "body": "use std.${1:io}",
    "description": "Import a standard library module"
  },
  "Test block": {
    "prefix": "test",
    "body": [
      "test \"${1:description}\" {",
      "\t$0",
      "}"
    ],
    "description": "Declare a test block"
  },
  "Parallel block": {
    "prefix": "parallel",
    "body": [
      "parallel {",
      "\ttask A {",
      "\t\t$1",
      "\t}",
      "\ttask B {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Thread-backed parallel execution block"
  },
  "Concurrent block": {
    "prefix": "concurrent",
    "body": [
      "concurrent {",
      "\ttask reader {",
      "\t\t$1",
      "\t}",
      "\ttask writer {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Same-thread cooperative concurrent block"
  },
  "Spawn and await": {
    "prefix": "spawn",
    "body": [
      "var ${1:handle} = spawn ${2:someAction}($3)",
      "var ${4:result} = await ${1:handle}"
    ],
    "description": "Spawn deferred work and await the result"
  },
  "Check statement": {
    "prefix": "check",
    "body": [
      "check ${1:value} {",
      "\t${2:pattern} => {",
      "\t\t$3",
      "\t}",
      "\t_ => {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Pattern-matching check statement"
  },
  "Raw string": {
    "prefix": "raw",
    "body": "r\"${1:literal \\\\n \\{value\\}}\"",
    "description": "Insert a raw string literal without escapes or interpolation"
  },
  "Print": {
    "prefix": "print",
    "body": "print(${1:\"Hello, world!\"})",
    "description": "Print to stdout"
  },
  "Shared value": {
    "prefix": "shared",
    "body": "var ${1:shared} = Shared(${0:value})",
    "description": "Wrap a value in a Shared handle"
  },
  "WeakShared handle": {
    "prefix": "weakshared",
    "body": "var ${1:weak} = WeakShared(${0:shared})",
    "description": "Create a WeakShared handle from a Shared value"
  }
}