{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "Node16",
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}