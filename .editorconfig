# Top-most EditorConfig file
root = true

# Global settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# JavaScript & TypeScript
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
quote_type = single
max_line_length = 100

# JSON (strict formatting)
[*.json]
indent_style = space
indent_size = 2
quote_type = double

# Markdown (keep trailing spaces for line breaks)
[*.md]
trim_trailing_whitespace = false

# Config files (optional tweak)
[*.{yml,yaml}]
indent_style = space
indent_size = 2
